// Vitest Snapshot v1, https://vitest.dev/guide/snapshot.html

exports[`campaign subcommands --help > campaign config has consistent help output 1`] = `
"Usage: campaign config [options] [subcommand]

Show or print the path of the active campaign's config

Arguments:
  subcommand  show or path (default: "show")

Options:
  --reveal    show secrets in clear text (default: redacted)
  -h, --help  display help for command
"
`;

exports[`command --help output > answer has consistent help output 1`] = `
"Usage: answer [options] [command] [slug] [question]

Generate or show answers to application questions (slug inferred from cwd if
omitted)

Arguments:
  slug            application slug (inferred from cwd if omitted)
  question        question to answer (or use --stdin)

Options:
  --image <path>  include a screenshot or image
  --stdin         read the question from stdin
  --steer <text>  instructions to guide this answer
  --no-save       print to stdout only (skip file write)
  -h, --help      display help for command

Commands:
  show [slug]     Show existing Q&A entries (slug inferred from cwd if omitted)
"
`;

exports[`command --help output > campaign has consistent help output 1`] = `
"Usage: campaign [options] [command]

Operations on a campaign

Options:
  -h, --help                     display help for command

Commands:
  config [options] [subcommand]  Show or print the path of the active campaign's
                                 config
  init
  rename
  doctor
  repair
  stats
  help [command]                 display help for command
"
`;

exports[`command --help output > config has consistent help output 1`] = `
"Usage: config [options] [subcommand]

Show or print the path of the global config

Arguments:
