exports[`command --help output > retro has consistent help output 1`] = `
"Usage: retro [options] [command] [slug]

Post-mortem for failed interviews (slug inferred from cwd if omitted)

Arguments:
  slug                    application slug (inferred from cwd if omitted)

Options:
  --interview <index>     retro for a specific interview index
  --weak-topics <topics>  comma-separated weak topics (prompts interactively if
                          omitted)
  --notes <text>          additional context notes
  --steer <text>          instructions to guide the learning plan generation
  -h, --help              display help for command

Commands:
  show [slug]             Display the most recent retro (slug inferred from cwd
                          if omitted)
  append [slug]           Add weak topics to the existing retro (slug inferred
                          from cwd if omitted)
  aggregate [options]     Show recurring weak topics across all applications
"
`;

exports[`command --help output > show has consistent help output 1`] = `
"Usage: show [options] [slug]

Show one application summary (slug inferred from cwd if omitted)

Arguments:
  slug        application slug (inferred from cwd if omitted)

Options:
  --json      output as JSON
  --jd        show job description
  -h, --help  display help for command
"
`;

exports[`command --help output > stats has consistent help output 1`] = `
"Usage: stats [options]

Show a campaign snapshot: counts by status, role, site, funnel

Options:
  --role <role>             filter stats by target role
  --employment-type <type>  filter stats by employment type
                            (permanent|temp|contract|casual|part-time)
  --since <date>            only count applications since a date (ISO or
                            relative: 7d, 30d, 90d)
  --include-notes           include LLM-extracted abandonment reasons (costs
                            tokens)
  --json                    output as JSON
  -h, --help                display help for command
"
`;

exports[`command --help output > track has consistent help output 1`] = `
"Usage: track [options] [urlOrSlug]

Record a new application (or update by slug)

Arguments:
  urlOrSlug             job posting URL or existing application slug

Options:
  --paste               paste job description from clipboard
  --stdin               read job description from stdin
  --status <status>     initial status (one of: applied, interview, offer,
                        rejected, withdrawn, abandoned, ghosted, accepted)
  --salary <range>      salary or pay range
  --tag <tag>           add a tag (repeatable) (default: [])
  --note <text>         add a note
  --target-role <role>  target role for the application
  --steer <text>        instructions to guide the LLM output
  --refresh             re-fetch job description from stored URL
  -y, --yes             skip confirmation prompts
  -h, --help            display help for command
"
`;

exports[`interview subcommands --help > interview add has consistent help output 1`] = `
"Usage: interview add [options] [slug]

Add an interview entry (slug inferred from cwd if omitted)

Arguments:
  slug                   application slug (inferred from cwd if omitted)

Options:
  --when <datetime>      interview date/time (e.g. "2026-06-15 10:00")
  --type <type>          interview type (hr, technical, system-design,
                         behavioural, take-home, final, other) (default:
                         "technical")
  --duration <minutes>   duration in minutes (default: "60")
  --interviewer <name>   interviewer name
  --location <location>  interview location or link
  --title <title>        interview title
  -h, --help             display help for command
"
`;

