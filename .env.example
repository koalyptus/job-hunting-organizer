# Config home (defaults to ~/.job-hunting-organizer/)
# JHO_CONFIG_HOME=/home/<user>/.job-hunting-organizer

# Campaign data root (defaults to ~/job-hunting-organizer-data/)
# JHO_DATA=/home/<user>/job-hunting-organizer-data

# Default campaign name (defaults to "default")
# JHO_DEFAULT_CAMPAIGN=default

# Logging
# JHO_LOG_LEVEL=debug|info|warn|error|silent
# JHO_LOG_FILE=/tmp/jho.log

# LLM provider (OpenAI-compatible)
# Examples:
#   Ollama:   http://localhost:11434/v1
#   OpenCode: http://localhost:8080/v1
#   LM Studio: http://localhost:1234/v1
#   OpenAI:   https://api.openai.com/v1
LLM_BASE_URL=http://localhost:11434/v1
LLM_API_KEY=ollama
LLM_MODEL=llama3.1

# Init wizard pre-fills
# JHO_CV_PATH=/home/<user>/cv.pdf
# JHO_LINKEDIN_URL=https://linkedin.com/in/<username>
# JHO_KB_PATH=/home/<user>/knowledge-base

# GitHub (optional, raises API rate limit)
# GITHUB_TOKEN=

# Microsoft Graph (optional, for Outlook calendar provider)
# OUTLOOK_TENANT_ID=
# OUTLOOK_CLIENT_ID=
# OUTLOOK_CLIENT_SECRET=

# Custom job-ID extraction patterns (optional)
# JSON array of { name: string, pattern: string, group: number }.
# Prepended to built-in patterns (Seek, LinkedIn, Indeed, generic).
# Invalid entries are silently skipped.
# JHO_URL_PATTERNS=[{"name":"workable","pattern":"workable\.com/j/(\\d+)","group":1}]
