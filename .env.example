# Campaign root (defaults to ~/job-hunting-organizer/)
# JHO_ROOT=/home/<user>/job-hunting-organizer

# Logging
# JHO_LOG_LEVEL=debug|info|warn|error|silent
# JHO_LOG_FILE=/tmp/jho.log

# LLM provider (OpenAI-compatible)
# Examples:
#   Ollama:   http://localhost:11434/v1
#   OpenCode: http://localhost:8080/v1
#   LM Studio: http://localhost:1234/v1
#   OpenAI:   https://api.openai.com/v1
LLM_BASE_URL=http://localhost:11434/v1
LLM_API_KEY=ollama
LLM_MODEL=llama3.1

# GitHub (optional, raises API rate limit)
# GITHUB_TOKEN=

# Microsoft Graph (optional, for Outlook calendar provider)
# OUTLOOK_TENANT_ID=
# OUTLOOK_CLIENT_ID=
# OUTLOOK_CLIENT_SECRET=
